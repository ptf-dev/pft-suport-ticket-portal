// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN
  CLIENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  BACKLOG
  LOW
  MEDIUM
  HIGH
  EXTRA_HIGH
  URGENT
  ULTRA_URGENT
}

enum NotificationTemplateType {
  TICKET_CREATED
  STATUS_CHANGED
  NEW_COMMENT
  TICKET_RESOLVED
  TICKET_ASSIGNED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum TicketRelationType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
  IS_IDEA_FOR
  WILL_IMPLEMENT_AFTER
  ADDED_TO_ROADMAP
}

enum ActivityType {
  CREATED
  EDITED
  DELETED
  RESTORED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  SCHEDULED
  UNSCHEDULED
  CATEGORY_CHANGED
  COMMENTED
  COMMENT_EDITED
  COMMENT_DELETED
  INTERNAL_NOTE
  IMAGE_UPLOADED
  IMAGE_DELETED
  RELATION_ADDED
  RELATION_REMOVED
  MENTIONED
}

// ============================================================================
// MODELS
// ============================================================================

model Company {
  id           String   @id @default(cuid())
  name         String
  /// Super-Admin projectId — links this brand to a dashboard deployment
  projectId    String?  @unique
  subdomain    String   @unique // For tenant resolution
  contactEmail String
  whatsappLink String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  users                User[]
  tickets              Ticket[]
  notificationSettings NotificationSettings?
  emailTemplates       EmailTemplate[]
  notificationLogs     NotificationLog[]

  @@map("companies")
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String
  password               String
  role                   Role
  companyId              String?
  isActive               Boolean   @default(true)
  resetPasswordToken     String?   @unique
  resetPasswordExpiresAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  company         Company?        @relation(fields: [companyId], references: [id])
  createdTickets  Ticket[]        @relation("TicketCreator")
  assignedTickets Ticket[]        @relation("TicketAssignment")
  comments        TicketComment[]
  ticketRelations TicketRelation[]
  activities      TicketActivity[]

  // Composite unique constraint for tenant isolation
  @@unique([email, companyId])
  @@map("users")
}

model Ticket {
  id           String         @id @default(cuid())
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?
  companyId    String // Always required for tenant scoping
  createdById  String
  assignedToId String? // References User.id, nullable
  assignedAt   DateTime? // Timestamp of assignment
  scheduledDate DateTime? // Date when ticket is scheduled to be worked on
  resolvedAt   DateTime? // Set when status becomes RESOLVED, cleared when leaving RESOLVED
  // Boomerang tracking — see lib/boomerang.ts
  bounceCount    Int      @default(0) // # of times status went WAITING_CLIENT -> OPEN/IN_PROGRESS
  reopenedAt     DateTime? // When it was last bounced back from WAITING_CLIENT
  reopenedByRole Role? // Who bounced it back last (CLIENT = real frustration signal)
  isDeleted    Boolean        @default(false) // Soft delete flag
  deletedAt    DateTime? // When ticket was deleted
  deletedBy    String? // Admin who deleted the ticket
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  company          Company           @relation(fields: [companyId], references: [id])
  createdBy        User              @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo       User?             @relation("TicketAssignment", fields: [assignedToId], references: [id])
  comments         TicketComment[]
  images           TicketImage[]
  notificationLogs NotificationLog[]
  relationsAsSource TicketRelation[] @relation("TicketRelationSource")
  relationsAsTarget TicketRelation[] @relation("TicketRelationTarget")
  activities       TicketActivity[]

  @@index([assignedToId])
  @@index([scheduledDate])
  @@index([updatedAt])
  @@index([resolvedAt])
  @@index([bounceCount])
  @@index([companyId, isDeleted, updatedAt])
  @@map("tickets")
}

model TicketComment {
  id             String   @id @default(cuid())
  ticketId       String
  authorId       String
  message        String
  internal       Boolean  @default(false)
  mentionedUsers String[] @default([]) // Array of user emails mentioned in comment
  createdAt      DateTime @default(now())

  // Relations
  ticket Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User           @relation(fields: [authorId], references: [id])
  images CommentImage[]

  @@map("ticket_comments")
}

model CommentImage {
  id         String   @id @default(cuid())
  commentId  String
  filename   String
  url        String
  size       Int
  mimeType   String
  uploadedAt DateTime @default(now())

  // Relations
  comment TicketComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("comment_images")
}

model TicketImage {
  id         String   @id @default(cuid())
  ticketId   String
  filename   String
  url        String
  size       Int
  mimeType   String
  uploadedAt DateTime @default(now())

  // Relations
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_images")
}

model NotificationSettings {
  id                        String   @id @default(cuid())
  companyId                 String   @unique
  emailNotificationsEnabled Boolean  @default(true)
  notifyOnStatusChange      Boolean  @default(true)
  notifyOnNewComments       Boolean  @default(true)
  notifyOnTicketAssignment  Boolean  @default(false)
  notifyOnTicketResolution  Boolean  @default(true)
  customEmailTemplates      Boolean  @default(false)
  recipientEmails           String[] @default([])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@map("notification_settings")
}

model EmailTemplate {
  id           String                   @id @default(cuid())
  companyId    String
  templateType NotificationTemplateType
  subject      String
  htmlBody     String
  textBody     String
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, templateType])
  @@map("email_templates")
}

model NotificationLog {
  id             String                   @id @default(cuid())
  companyId      String
  ticketId       String?
  templateType   NotificationTemplateType
  recipientEmail String
  subject        String
  status         NotificationStatus       @default(PENDING)
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime                 @default(now())

  // Relations
  company Company @relation(fields: [companyId], references: [id])
  ticket  Ticket? @relation(fields: [ticketId], references: [id])

  @@map("notification_logs")
}

model SMTPSettings {
  id              String    @id @default(cuid())
  host            String
  port            Int
  secure          Boolean   @default(true)
  username        String
  password        String // Encrypted with AES-256-GCM
  senderEmail     String
  senderName      String
  isActive        Boolean   @default(false)
  lastTestedAt    DateTime?
  lastTestSuccess Boolean?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String
  updatedBy       String

  @@map("smtp_settings")
}

model TicketRelation {
  id             String               @id @default(cuid())
  sourceTicketId String
  targetTicketId String
  relationType   TicketRelationType
  createdAt      DateTime             @default(now())
  createdById    String?

  sourceTicket   Ticket               @relation("TicketRelationSource", fields: [sourceTicketId], references: [id], onDelete: Cascade)
  targetTicket   Ticket               @relation("TicketRelationTarget", fields: [targetTicketId], references: [id], onDelete: Cascade)
  createdBy      User?                @relation(fields: [createdById], references: [id])

  @@unique([sourceTicketId, targetTicketId, relationType])
  @@index([sourceTicketId])
  @@index([targetTicketId])
  @@map("ticket_relations")
}

model TicketActivity {
  id         String       @id @default(cuid())
  ticketId   String
  actorId    String?
  type       ActivityType
  fromValue  String?
  toValue    String?
  message    String?
  meta       Json?
  createdAt  DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([ticketId, createdAt])
  @@index([createdAt])
  @@index([type])
  @@map("ticket_activities")
}
