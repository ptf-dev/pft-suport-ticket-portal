{
  "name": "propfirms-ticketing-mcp",
  "version": "1.0.0",
  "description": "MCP server for PropFirms ticketing system - allows LLMs to read and interact with support tickets",
  "type": "module",
  "bin": {
    "propfirms-ticketing-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\" && node -e \"require('fs').chmodSync('build/http-server.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "dev": "node --loader ts-node/esm src/index.ts",
    "dev:http": "node --loader ts-node/esm src/http-server.ts",
    "start": "node build/http-server.js"
  },
  "keywords": [
    "mcp",
    "ticketing",
    "support",
    "propfirms"
  ],
  "author": "PropFirms Tech",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0"
  }
}
