# PropFirms Ticketing MCP Server Configuration

# Your ticketing system base URL
TICKETING_BASE_URL=https://portal.propfirmstech.com

# API Key for authentication (generate a secure key)
TICKETING_API_KEY=your-secure-api-key-here

# MCP Server API Key (for client authentication)
MCP_SERVER_API_KEY=your-mcp-server-api-key-here

# Port for HTTP server (default: 3001)
MCP_SERVER_PORT=3001

# Optional: Enable debug logging
DEBUG=false
